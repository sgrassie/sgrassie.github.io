---
layout: null
---
[
  {% for post in site.posts %}
    {
      "title"    : {{ post.title | jsonify }},
      "category" : "{{ post.category }}",
      "tags"     : "{{ post.tags | join: ', ' }}",
      "url"      : "{{ site.baseurl }}{{ post.url }}",
      "date"     : "{{ post.date | date: '%Y-%m-%d' }}",
      "pretty_date" : "{{ post.date | date: '%-d %b %Y' }}"
    } {% unless forloop.last %},{% endunless %}
  {% endfor %}
]
